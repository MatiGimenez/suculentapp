{
  "name": "suculentapp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "pnpm --filter=mobile exec expo start",
    "dev:mobile:ios": "pnpm --filter=mobile exec expo start --ios --clear",
    "dev:mobile:android": "pnpm --filter=mobile exec expo start --android --clear",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.5.3",
    "turbo": "^2.8.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0"
  },
  "packageManager": "pnpm@10.18.3"
}