{
  "extends": "@suculentapp/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "allowJs": true,
